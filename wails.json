{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "Masterboard",
  "outputfilename": "Masterboard",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "author": {
    "name": "Intermezzo Software",
    "email": "devin@intermezzosoftware.co.uk"
  },
  "info": {
    "companyName": "Intermezzo Software",
    "productName": "Masterboard",
    "productVersion": "v0.6.5",
    "copyright": "Copyright © 2026 Intermezzo Software",
    "comments": "A desktop chess application for serious players.",
    "protocols": [
      {
        "scheme": "io.masterboard.app",
        "description": "Masterboard",
        "role": "Viewer"
      }
    ],
    "fileAssociations": [
      {
        "ext": "pgn",
        "name": "PGN Game File",
        "description": "Portable Game Notation chess file",
        "iconName": "pgn-icon",
        "role": "Editor"
      }
    ]
  }
}
