# Wails build outputs
build/bin/

# Frontend build artifacts
frontend/dist/
frontend/node_modules/

# Website build artifacts (source is tracked; only generated output is excluded)
website/dist/
website/.astro/
website/test-results/

# Root-level node_modules (should not exist, but guard against accidental npm init)
node_modules/

# Auto-generated Wails bindings (regenerated by `wails dev`)
frontend/wailsjs/

# Go build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
# Wails-generated Windows resource file (produced by wails build; not a source file)
*.syso

# Vendored go-webview2 ships WebView2Loader.dll binaries for the
# native_webview2loader build path. The default loader is pure Go and does
# not need them, but we keep the vendored tree complete for anyone who
# opts into -tags native_webview2loader. See third_party/go-webview2/PATCH_NOTES.md.
!third_party/go-webview2/**/*.dll

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
.env.local
.env.*.local

# Claude Code local state
.claude/
.playwright-mcp/
.superpowers/

# Temporary scaffolding (remove after initial setup)
tmp-scaffold/
tmp/

# build/bin/ is already excluded above; the rest of build/ (platform templates,
# icons, installer scripts) are source files and ARE tracked.
# Generated exceptions: wails_tools.nsh and derived .ico files (built from PNG sources).
build/windows/installer/wails_tools.nsh
build/windows/icon.ico
build/windows/installer-icon.ico
build/windows/pgn-icon.ico
claude-comms/
/docs/
frontend/test-results/
human-notes/
test-results/
tools/

# Raw screenshots (large PNGs; processed WebPs in website/public/screenshots/ are tracked)
website/screenshots-raw/

# Git worktrees
.worktrees/

# Perf harness run output (scenario metrics + Playwright reports)
frontend/perf-results*.jsonl
frontend/perf/perf-playwright*.json
.worktrees/
